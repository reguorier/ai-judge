{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-judge.dev/schemas/hermes-output.json",
  "title": "Hermes Output Envelope",
  "description": "Sanitized AI Judge output for Hermes display surface.",
  "type": "object",
  "required": ["schema_version", "run_id", "question", "consensus_map"],
  "properties": {
    "schema_version": { "type": "string", "const": "ai-judge-hermes-output-v1" },
    "run_id": { "type": "string" },
    "question": { "type": "string" },
    "timestamp": { "type": "string" },
    "seats_engaged": { "type": "integer" },
    "claims_total": { "type": "integer" },
    "consensus_map": {
      "type": "object",
      "properties": {
        "consensus": { "type": "integer" },
        "split": { "type": "integer" },
        "dissent": { "type": "integer" }
      }
    },
    "top_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": { "type": "string" },
          "score": { "type": "number" },
          "agree_count": { "type": "integer" }
        }
      }
    },
    "dissent_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": { "type": "string" },
          "agree_count": { "type": "integer" },
          "confidence": { "type": "number" }
        }
      }
    }
  }
}
